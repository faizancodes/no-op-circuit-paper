# HuggingFace — needed inside Modal to download Qwen/CodeGemma/etc.
HF_TOKEN=

# OpenRouter — used for any LLM-assisted dataset generation or validation.
OPENROUTER_API_KEY=

# Optional / reserved
OPENAI_API_KEY=
GITHUB_TOKEN=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
